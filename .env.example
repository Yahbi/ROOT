# ROOT Configuration — set ONE of these API keys (or both)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Provider: "auto" (detect from keys), "anthropic", or "openai"
ROOT_LLM_PROVIDER=auto

# Server
ROOT_HOST=127.0.0.1
ROOT_PORT=9000

# Anthropic model tiers
ROOT_MODEL=claude-sonnet-4-6
ROOT_THINKING_MODEL=claude-opus-4-6
ROOT_FAST_MODEL=claude-haiku-4-5-20251001

# OpenAI model tiers
ROOT_OPENAI_MODEL=gpt-4o
ROOT_OPENAI_THINKING_MODEL=gpt-4o
ROOT_OPENAI_FAST_MODEL=gpt-4o-mini

# Memory
ROOT_MEMORY_MAX=10000
ROOT_REFLECTION_INTERVAL=3600

# External services
HERMES_DIR=~/Desktop/HERMES
ASTRA_URL=http://localhost:5555
MIRO_URL=http://localhost:8080
SWARM_DIR=~/Desktop/swarm-temp
OPENCLAW_URL=http://localhost:3001

# Owner
ROOT_OWNER=Yohan Bismuth
