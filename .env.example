# ══════════════════════════════════════════════════════════════
# ROOT v1.0.0 — ASTRA-ROOT Intelligence Civilization
# Complete configuration template — copy to .env and fill in
# ══════════════════════════════════════════════════════════════

# ── MASTER API KEY (universal fallback for all services) ──
ROOT_MASTER_API_KEY=

# ── LLM Providers (cascading: anthropic → openai → groq → deepseek → ollama) ──

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
NEMOTRON_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=

# Provider routing
ROOT_LLM_PROVIDER=auto

# ── Model Tiers ──

ROOT_MODEL=claude-sonnet-4-6
ROOT_THINKING_MODEL=claude-opus-4-6
ROOT_FAST_MODEL=claude-haiku-4-5-20251001

ROOT_OPENAI_MODEL=gpt-4o
ROOT_OPENAI_THINKING_MODEL=gpt-4o
ROOT_OPENAI_FAST_MODEL=gpt-4o-mini

ROOT_GROQ_MODEL=llama-3.3-70b-versatile
ROOT_GROQ_FAST_MODEL=llama-3.1-8b-instant
ROOT_GROQ_THINKING_MODEL=deepseek-r1-distill-llama-70b

# Ollama (local, free — install: ollama pull gemma3:4b)
OLLAMA_BASE_URL=http://localhost:11434
ROOT_OLLAMA_MODEL=gemma3:4b
ROOT_OLLAMA_FAST_MODEL=gemma3:4b
ROOT_OLLAMA_THINKING_MODEL=gemma3:4b

# ── Trading (free paper trading at alpaca.markets) ──
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Market Data ──
FINNHUB_API_KEY=

# ── Prediction Markets ──
POLYMARKET_PRIVATE_KEY=

# ── Notifications ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=

# ── Cost Budgets (0 = unlimited) ──
LLM_DAILY_BUDGET=0
LLM_MONTHLY_BUDGET=0

# ── Server ──
ROOT_HOST=127.0.0.1
ROOT_PORT=9000

# ── Memory ──
ROOT_MEMORY_MAX=10000
ROOT_REFLECTION_INTERVAL=3600

# ── External Services ──
HERMES_DIR=~/Desktop/HERMES
SWARM_DIR=~/Desktop/swarm-temp
OPENCLAW_URL=http://localhost:3000

# ── Owner ──
ROOT_OWNER=Yohan Bismuth
